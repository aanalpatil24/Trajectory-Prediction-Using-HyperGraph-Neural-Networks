{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# HGNN Trajectory Prediction - Interactive Demo\n",
    "\n",
    "This notebook demonstrates the Sequence-to-Sequence HyperGraph Neural Network for multi-agent trajectory prediction."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, '../')\n",
    "\n",
    "import torch\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "from src.models.seq2seq_hgnn import Seq2SeqHGNN\n",
    "from src.data.dataset import SyntheticTrajectoryDataset\n",
    "from src.data.dataloader import get_dataloader\n",
    "from src.utils.config import ModelConfig\n",
    "from src.utils.visualization import plot_trajectories, plot_hypergraph, plot_training_history\n",
    "\n",
    "print("PyTorch version:", torch.__version__)\n",
    "print("CUDA available:", torch.cuda.is_available())"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Configuration"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create configuration\n",
    "config = ModelConfig(\n",
    "    hidden_dim=128,\n",
    "    num_hgnn_layers=2,\n",
    "    dbscan_eps=2.0,\n",
    "    obs_len=8,\n",
    "    pred_len=12,\n",
    "    batch_size=16,\n",
    "    device='cuda' if torch.cuda.is_available() else 'cpu'\n",
    ")\n",
    "\n",
    "print(config)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Data Generation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create synthetic dataset with group behaviors\n",
    "dataset = SyntheticTrajectoryDataset(\n",
    "    num_samples=100,\n",
    "    obs_len=config.obs_len,\n",
    "    pred_len=config.pred_len,\n",
    "    num_agents_range=(5, 15),\n",
    "    group_behavior_prob=0.7,\n",
    "    seed=42\n",
    ")\n",
    "\n",
    "# Get a sample\n",
    "sample = dataset[0]\n",
    "obs = sample['obs']\n",
    "pred = sample['pred']\n",
    "\n",
    "print(f"Observation shape: {obs.shape}")\n",
    "print(f"Prediction shape: {pred.shape}")\n",
    "\n",
    "# Visualize\n",
    "plot_trajectories(obs.numpy(), pred.numpy(), title="Sample Crowd Scene")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Model Architecture"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create model\n",
    "model = Seq2SeqHGNN(config)\n",
    "\n",
    "# Count parameters\n",
    "total_params = sum(p.numel() for p in model.parameters())\n",
    "trainable_params = sum(p.numel() for p in model.parameters() if p.requires_grad)\n",
    "\n",
    "print(f"Total parameters: {total_params:,}")\n",
    "print(f"Trainable parameters: {trainable_params:,}")\n",
    "\n",
    "# Model structure\n",
    "print("\nModel Architecture:")\n",
    "print(model)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Hypergraph Visualization"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Get hypergraph structure\n",
    "obs_batch = obs.unsqueeze(0).to(config.device)\n",
    "\n",
    "with torch.no_grad():\n",
    "    output = model(obs_batch, return_metadata=True)\n",
    "    metadata = output['metadata'][0]\n",
    "\n",
    "print(f"Number of hyperedges (groups): {metadata['num_hyperedges']}")\n",
    "print(f"Average group size: {metadata['avg_group_size']:.2f}")\n",
    "print(f"Isolated agents: {metadata['num_isolated']}")\n",
    "\n",
    "# Visualize hypergraph\n",
    "last_positions = obs[-1].numpy()\n",
    "plot_hypergraph(\n",
    "    positions=last_positions,\n",
    "    hyperedges=metadata['hyperedges'],\n",
    "    title="Social Groups (Hyperedges)"\n",
    ")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Training Demo"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from src.training.trainer import Trainer\n",
    "\n",
    "# Create small datasets for demo\n",
    "train_dataset = SyntheticTrajectoryDataset(\n",
    "    num_samples=50, config=config, num_agents_range=(5, 10), seed=42\n",
    ")\n",
    "val_dataset = SyntheticTrajectoryDataset(\n",
    "    num_samples=20, config=config, num_agents_range=(5, 10), seed=43\n",
    ")\n",
    "\n",
    "train_loader = get_dataloader(train_dataset, batch_size=4, shuffle=True)\n",
    "val_loader = get_dataloader(val_dataset, batch_size=4, shuffle=False)\n",
    "\n",
    "# Train for a few epochs\n",
    "config.num_epochs = 5\n",
    "trainer = Trainer(model, config, train_loader, val_loader)\n",
    "trainer.train()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Prediction Visualization"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Get predictions\n",
    "model.eval()\n",
    "with torch.no_grad():\n",
    "    output = model(obs_batch)\n",
    "    predictions = output['predictions'][0]\n",
    "\n",
    "# Visualize\n",
    "plot_trajectories(\n",
    "    obs_trajectory=obs.numpy(),\n",
    "    pred_trajectory=predictions.cpu().numpy(),\n",
    "    gt_trajectory=pred.numpy(),\n",
    "    title="Predicted vs Ground Truth Trajectories"\n",
    ")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Metrics Evaluation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from src.training.metrics import evaluate_all_metrics, print_metrics\n",
    "\n",
    "# Compute metrics\n",
    "metrics = evaluate_all_metrics(\n",
    "    predictions=predictions.unsqueeze(0).cpu().numpy(),\n",
    "    ground_truth=pred.unsqueeze(0).numpy()\n",
    ")\n",
    "\n",
    "print_metrics(metrics)"
   ]
  }
 ],
